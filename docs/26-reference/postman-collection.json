{
  "info": {
    "name": "Portfolio API",
    "description": "Enterprise portfolio platform API. Public portfolio endpoints + admin CRUD.\n\n## Auth\n- Register, login → get `access_token`\n- Set `{{auth_token}}` environment variable\n- Bearer token auto-included in Admin requests\n\n## Pagination\nMost `findAll` endpoints accept `page`, `perPage`, `search`, `sortBy`, `sortOrder` query params.\n\n## Rate Limits\n- Login: 5/min\n- Register: 3/min\n- Refresh: 20/min\n- Global: 100/60s\n\n## Caching\nPublic portfolio endpoints cached via Redis (5-min TTL). Invalidate on admin writes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001", "type": "string" },
    { "key": "auth_token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@portfolio.com\",\n  \"password\": \"***REDACTED***\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "auth", "login"]
            }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"new@portfolio.com\",\n  \"password\": \"User1234!\",\n  \"display_name\": \"New User\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "auth", "register"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"your-refresh-token\"\n}" },
            "url": {
              "raw": "{{base_url}}/api/admin/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "auth", "refresh"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"your-refresh-token\"\n}" },
            "url": {
              "raw": "{{base_url}}/api/admin/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "auth", "logout"]
            }
          }
        }
      ]
    },
