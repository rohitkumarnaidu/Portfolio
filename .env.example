# ══════════════════════════════════════════════════════════════
# ENVIRONMENT VARIABLES — Portfolio Platform
# ══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# Reference: docs/SystemArchitecture.md §10 (Environment Configuration)
# ══════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Authentication (JWT) ─────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourSecurePassword123!

# ── NextAuth.js (Admin Dashboard) ────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# ── Site Configuration ───────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_AI_URL=http://localhost:8000

# ── OpenAI (AI Assistant) ────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Anthropic (AI Fallback) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-3-haiku-20240307

# ── AI Budget Controls ───────────────────────────────────────
AI_DAILY_BUDGET_USD=0.50
AI_MONTHLY_BUDGET_USD=10.00
AI_MAX_REQUESTS_PER_SESSION=20

# ── PostHog (Analytics) ──────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Sentry (Error Tracking) ──────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=sntrys_your-auth-token
SENTRY_ORG=your-org
SENTRY_PROJECT=portfolio-web

# ── Resend (Email) ───────────────────────────────────────────
RESEND_API_KEY=re_your-resend-key
RESEND_FROM_EMAIL=hello@yourdomain.com
RESEND_REPLY_TO=reply@yourdomain.com

# ── Telegram (Alerts) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ── Better Uptime (Monitoring) ───────────────────────────────
BETTER_UPTIME_API_KEY=your-better-uptime-key

# ── API Service (NestJS) ─────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# ── AI Service (FastAPI) ─────────────────────────────────────
AI_PORT=8000
AI_CORS_ORIGIN=http://localhost:3000
