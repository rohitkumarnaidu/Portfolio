# ══════════════════════════════════════════════════════════════
# ENVIRONMENT VARIABLES — NestJS API
# ══════════════════════════════════════════════════════════════
# Used by docker-compose.yml and the NestJS API server.
# For Next.js frontend env vars, see ../.env.example.
# For AI service (FastAPI) env vars, see ../apps/ai/.env.example.
# ══════════════════════════════════════════════════════════════

# Supabase / Database
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Authentication
JWT_SECRET=your-jwt-secret-key

# AI Service
OPENAI_API_KEY=your-openai-api-key

# Sentry (Error Tracking)
SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=your-sentry-public-dsn

# Redis (Caching & Queue)
REDIS_URL=redis://localhost:6379

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@portfolio.com
ADMIN_NOTIFICATION_EMAIL=admin@portfolio.com

# Account Lockout
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION_MS=900000

# ISR Revalidation
REVALIDATION_SECRET=your-revalidation-secret-here
