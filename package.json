{
  "name": "my-portfolio",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,jsx,json,md,css}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "dev:ai": "npm run start --workspace=apps/ai",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@portfolio/api": "^1.0.0",
    "@types/cookie-parser": "^1.4.10",
    "concurrently": "^8.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0"
  },
  "packageManager": "npm@10.8.0",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "entities": "^4.5.0"
  },
  "dependencies": {
    "@nestjs/schedule": "^6.1.3",
    "@portfolio/web": "^1.0.0",
    "cookie-parser": "^1.4.7",
    "isomorphic-dompurify": "^3.18.0"
  }
}
